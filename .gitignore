# ===========================
# Project Code - Git 忽略规则
# ===========================

# Cursor 编辑器配置
.cursorignore
.vscode/
.history/

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 临时文件
*.tmp
*.temp
*.log
*.bak

# Python 相关（如果使用）
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node.js 相关（如果使用）
node_modules/
package-lock.json
yarn.lock

# ===========================
# 项目特定忽略（根据需要调整）
# ===========================

# 不需要在源代码管理中显示的文件夹
Crystal/
00 通用/
Pseo脚本/
Thread螺纹加工/
transchats-extension/

