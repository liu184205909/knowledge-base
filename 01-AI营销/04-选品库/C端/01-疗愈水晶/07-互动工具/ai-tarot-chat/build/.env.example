# ============================================================
# AI Tarot Chat — 部署用 .env 示例
# ============================================================
# 部署时把此文件复制到 WordPress 根目录（与 wp-config.php 同级），
# 重命名为 .env，并填入真实 key。
#
# 路径示例：
#   /var/www/goearthward.com/.env
#   /home/user/public_html/.env
#
# snippet.php 启动时若未从 OS 环境读到 DEEPSEEK_API_KEY，
# 会自动解析此文件。
# ============================================================

DEEPSEEK_API_KEY=sk-在此填入你的真实 DeepSeek API Key

# 可选：直接通过 OS 环境变量注入（推荐用于 VPS / Docker）
# 在 PHP-FPM 的 www.conf 加： env[DEEPSEEK_API_KEY] = sk-xxx
# 或在 Apache 配置加：      SetEnv DEEPSEEK_API_KEY sk-xxx
# 或在 nginx 加：           fastcgi_param DEEPSEEK_API_KEY sk-xxx;
